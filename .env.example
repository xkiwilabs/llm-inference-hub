# === HuggingFace ===
# Get a token from https://huggingface.co/settings/tokens
HF_TOKEN=

# === Models ===
# See docs/04-managing-models.md for options
SMALL_MODEL=openai/gpt-oss-20b
LARGE_MODEL=

# === GPU Configuration ===
# Auto-detected by ./hub setup - override manually if needed
SMALL_MODEL_GPU=0
LARGE_MODEL_GPUS=0,1
TENSOR_PARALLEL_SIZE=1
GPU_MEMORY_UTILIZATION=0.90

# === vLLM ===
# Auto-set by ./hub setup based on CUDA version
VLLM_IMAGE_TAG=v0.8.4
TOOL_CALL_PARSER=hermes

# === LiteLLM ===
# Master key is generated by ./hub setup
LITELLM_MASTER_KEY=
LITELLM_PORT=4200

# === Database ===
# Password is generated by ./hub setup
POSTGRES_PASSWORD=
